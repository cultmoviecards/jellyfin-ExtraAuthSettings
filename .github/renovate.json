{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "github>jellyfin/.github//renovate-presets/default"
    ],
    "labels": [
        "dependencies"
    ],
    "rangeStrategy": "replace",
    "rebaseWhen": "behind-base-branch",
    "dependencyDashboard": true,
    "prConcurrentLimit": 5,
    "packageRules": [
        {
            "matchManagers": [
                "github-actions"
            ],
            "groupName": "github actions",
            "automerge": true,
            "automergeType": "pr",
            "matchUpdateTypes": [
                "minor",
                "patch",
                "digest"
            ]
        },
        {
            "matchManagers": [
                "nuget"
            ],
            "matchDepTypes": [
                "PackageReference"
            ],
            "matchPackageNames": [
                "SerilogAnalyzer",
                "SmartAnalyzers.MultithreadingAnalyzer",
                "StyleCop.Analyzers"
            ],
            "groupName": "analyzers",
            "automerge": true,
            "automergeType": "pr",
            "matchUpdateTypes": [
                "minor",
                "patch"
            ]
        },
        {
            "matchManagers": [
                "nuget"
            ],
            "matchPackageNames": [
                "Jellyfin.Controller",
                "Jellyfin.Model"
            ],
            "groupName": "jellyfin packages",
            "automerge": false
        },
        {
            "matchUpdateTypes": [
                "major"
            ],
            "dependencyDashboardApproval": true,
            "automerge": false
        }
    ]
}
